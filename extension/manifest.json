{
  "manifest_version": 3,
  "name": "Tier Ai",
  "version": "1.0",
  "description": "Скрапер товаров для Тир-листов",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*.leboncoin.fr/*",
    "https://httpbin.org/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "tierFolders.html",
        "parseList.html",
        "scanPreview.html"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
